# Servidor
PORT=3333
NODE_ENV=development                  # development | production
FRONTEND_URL=http://localhost:3000    # Para CORS

# Banco de dados — PostgreSQL no Railway (obrigatório)
DATABASE_URL=postgresql://user:password@host:5432/railway
DATABASE_SSL=false   # true ao usar o endpoint público do Railway (proxy.rlwy.net)

# JWT — mesma secret do NextAuth no frontend (obrigatório)
NEXTAUTH_SECRET=

# --- Integrações (opcionais na fase inicial, obrigatórias quando implementadas) ---

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_BUSINESS_PRICE_ID=price_...

# Focus NFe
FOCUS_NFE_API_KEY=
FOCUS_NFE_BASE_URL=https://homologacao.focusnfe.com.br

# Resend
RESEND_API_KEY=re_...
